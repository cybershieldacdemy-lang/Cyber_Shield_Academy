# ═══════════════════════════════════════════════════════════
#  Cyber Attack Intelligence Server — API Configuration
# ═══════════════════════════════════════════════════════════
#  Copy this file to .env and add your API keys.
#  All keys are OPTIONAL — the server runs in simulation
#  mode when no keys are configured.
# ═══════════════════════════════════════════════════════════

# AbuseIPDB — Malicious IP blacklists & reputation
# Free: 1,000 checks/day  |  https://www.abuseipdb.com/account/api
ABUSEIPDB_API_KEY=

# AlienVault OTX — Threat intelligence pulses & IOCs
# Free: Generous limits   |  https://otx.alienvault.com/api
OTX_API_KEY=

# GreyNoise — Internet background noise classification
# Free: 50 queries/day    |  https://docs.greynoise.io/docs/using-the-api
GREYNOISE_API_KEY=

# Shodan — Internet-connected device & vulnerability search
# Free: 100 credits/month |  https://account.shodan.io/
SHODAN_API_KEY=

# VirusTotal — File, URL, and IP reputation analysis
# Free: 4 requests/min    |  https://www.virustotal.com/gui/my-apikey
VIRUSTOTAL_API_KEY=

# ─── Server Ports ─────────────────────────────────────────
WS_PORT=3001
API_PORT=3002
